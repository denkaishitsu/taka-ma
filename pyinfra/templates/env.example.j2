# taka-ma 環境変数テンプレート（.env.example）
#
# このファイルは雛形である。実値は /opt/taka-ma/config/.env に記入し、
# .env は chmod 600・Git 管理外とする（絶対にコミットしない）。
# 各コンポーネントの構築手順書（03-slack-bot 等）が自分のキーを追記する。

# ── u-zu / Slack（03-slack-bot.md §3-1）──────────────────────
# Slack App から取得。Socket Mode 運用のため Webhook 公開は不要。
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C0...

# 複数ワークスペース運用時（03-slack-bot.md §3-4）。team_id ごとに追記する。
# app-level トークン（SLACK_APP_TOKEN）は全ワークスペース共通で 1 本。
# SLACK_BOT_TOKEN_<TEAM_ID>=xoxb-...
# SLACK_CHANNEL_ID_<TEAM_ID>=C0...

# ── パス・接続先の上書き（任意。未設定時は下記の既定値）──────────
# TAKA_MA_USERS_PATH=/opt/taka-ma/config/users.yaml
# TAKA_MA_YATA_PATH=/opt/taka-ma/ya-ta/config/ya-ta.yaml
# TAKA_MA_APPROVAL_DIR=/opt/taka-ma/data/approvals
# TAKA_MA_CONTROL_DIR=/opt/taka-ma/data/controls
# TAKA_MA_WORKER_HOST=mbp
